# Variáveis opcionais — NÃO são carregadas automaticamente.
# Passa-as na linha de comando, por exemplo:
#   CHROMEDRIVER_PATH=/caminho/chromedriver node src/tests/RF01.js

# URL do frontend (por defeito nos testes: http://localhost:5173)
APP_URL=http://localhost:5173

# URL da API (por defeito: http://127.0.0.1:3000)
API_URL=http://127.0.0.1:3000

# Chrome (obrigatório fora do macOS se não estiver no PATH)
CHROME_BIN=

# ChromeDriver manual (opcional; por defeito usa o pacote npm «chromedriver»)
CHROMEDRIVER_PATH=

# Credenciais (por defeito: valores do seed api/scripts/seed)
ADMIN_EMAIL=admin@demo.pt
ADMIN_PASSWORD=Demo2026!

ORGANIZADOR_EMAIL=organizador@demo.pt
ORGANIZADOR_PASSWORD=Demo2026!

VOLUNTARIO_EMAIL=voluntario1@demo.pt
VOLUNTARIO_PASSWORD=Demo2026!

# Pausa entre passos (ms)
TEST_DELAY_MS=1200
